		<owl:sameAs rdf:resource="#bjmns:3:1:0:2"/>
		<index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</index>
		<fullTitle xml:lang="en">In the Palm of My Hand</fullTitle>
		<isPublishedAs>
	<dcmitype:Text rdf:about="./3/1/0/2/text.html">
		<dc:format>
