	<Version rdf:about="tag:bjmns.tumblr.com,2013:bns::7:1:Ω">
		<owl:sameAs rdf:resource="./7/1/Ω/"/>
		<owl:sameAs rdf:resource="#bjmns:7:1:Ω"/>
		<identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#NCName">Ω</identifier>
		<index rdf:datatype="http://www.w3.org/2001/XMLSchema#NCName">Ω</index>
		<fullTitle xml:lang="en">The Legend of Ilia: Omega</fullTitle>
		<abbreviatedTitle xml:lang="en">Omega</abbreviatedTitle>
		<dc:abstract rdf:parseType="Resource">
			<contents rdf:parseType="Literal"><div xmlns="http://www.w3.org/1999/xhtml" lang="en" xml:lang="en">
	<p>Another attempt at simply converting over <a href="https://go.KIBI.family/Corpora/bjmns.tumblr.com,2013/6/" resource="tag:bjmns.tumblr.com,2013:bns::6"><code>bjmns:6</code></a> plotlines into a new world, which failed for the usual reason that none of the stories in <a href="https://go.KIBI.family/Corpora/bjmns.tumblr.com,2013/6/" resource="tag:bjmns.tumblr.com,2013:bns::6"><code>bjmns:6</code></a> <em>had</em> plotlines.</p>
</div></contents>
		</dc:abstract>
		<includes>
	<Draft rdf:about="tag:bjmns.tumblr.com,2013:bns::7:1:Ω:1">
		<owl:sameAs rdf:resource="./7/1/Ω/1/"/>
