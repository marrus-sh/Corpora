	<dcmitype:Text rdf:about="./7/1/1/:notes/The_Ballpoint_Pen-Tyneland/text.rtf">
		<dc:format>
	<dc:FileFormat>
		<dc:identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">application/rtf</dc:identifier>
