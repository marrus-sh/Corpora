		<includes>
	<Volume rdf:about="tag:bjmns.tumblr.com,2013:bns::6:Α">
		<owl:sameAs rdf:resource="./6/Α/"/>
		<owl:sameAs rdf:resource="#bjmns:6:Α"/>
		<identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#NCName">Α</identifier>
		<index rdf:datatype="http://www.w3.org/2001/XMLSchema#NCName">Α</index>
		<fullTitle xml:lang="en">The Legend of Ilia: Alpha</fullTitle>
		<abbreviatedTitle xml:lang="en">Alpha</abbreviatedTitle>
		<dc:abstract rdf:parseType="Resource">
			<contents rdf:parseType="Literal"><div xmlns="http://www.w3.org/1999/xhtml" lang="en" xml:lang="en">
	<p>The <em>original</em> <a href="https://go.KIBI.family/Corpora/bjmns.tumblr.com,2013/6/" resource="tag:bjmns.tumblr.com,2013:bns::6"><code>bjmns:6</code></a> story, and also both my first time writing fanfiction and my first time writing romance (<a href="https://go.KIBI.family/Corpora/bjmns.tumblr.com,2013/1/1/2003-03/" resource="tag:bjmns.tu mblr.com,2013:bns::1:1:2003-03"><code>bjmns:6</code></a> aside).  It’s also the only <a href="https://go.KIBI.family/Corpora/bjmns.tumblr.com,2013/6/" resource="tag:bjmns.tumblr.com,2013:bns::6"><code>bjmns:6</code></a> to actually ever be <em>finished</em> (for some sense of the word).</p>
</div></contents>
		</dc:abstract>
		<includes>
	<Version rdf:about="tag:bjmns.tumblr.com,2013:bns::6:Α:0">
