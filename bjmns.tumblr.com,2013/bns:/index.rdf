		<index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</index>
		<fullTitle xml:lang="en">The Legend of Ilia</fullTitle>
		<isPublishedAs>
	<rdf:Seq rdf:type="dcmitype:Text">
		<dc:format>
	<dc:FileFormat>
		<dc:identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">text/markdown</dc:identifier>
