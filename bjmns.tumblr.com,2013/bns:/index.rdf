		<identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#NCName">Ω1</identifier>
		<index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</index>
		<fullTitle xml:lang="en">Tyneland (or, The Legend of Ilia: Omega)</fullTitle>
		<abbreviatedTitle xml:lang="en">Tyneland</abbreviatedTitle>
		<isPublishedAs>
	<dcmitype:Text rdf:about="./7/1/Ω/1/text.html">
		<dc:format>
	<dc:FileFormat>
		<dc:identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">text/html</dc:identifier>
	</dc:FileFormat>
		</dc:format>
