	<dcmitype:Text rdf:about="./7/1/Ω/1/text.rtf">
		<dc:format>
	<dc:FileFormat>
		<dc:identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#string">application/rtf</dc:identifier>
	</dc:FileFormat>
		</dc:format>
	</dcmitype:Text>
