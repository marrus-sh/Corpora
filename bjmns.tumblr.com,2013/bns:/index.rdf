	<Project rdf:about="tag:bjmns.tumblr.com,2013:bns::5">
		<owl:sameAs rdf:resource="./5/"/>
		<owl:sameAs rdf:resource="#bjmns:5"/>
		<identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#NCName">mantle</identifier>
		<fullTitle xml:lang="en">Edgar Mantle</fullTitle>
		<inspiration rdf:resource="http://www.wikidata.org/entity/Q325283"/>
		<inspiration rdf:resource="http://id.loc.gov/resources/works/12277346"/>
		<inspiration rdf:resource="http://id.loc.gov/resources/works/13438767"/>
		<inspiration rdf:resource="http://id.loc.gov/resources/works/13130279"/>
		<inspiration rdf:resource="http://id.loc.gov/resources/works/14220523"/>
		<inspiration rdf:resource="http://id.loc.gov/authorities/subjects/sh2008103468"/>
		<dc:abstract rdf:parseType="Resource">
			<contents rdf:parseType="Literal"><div xmlns="http://www.w3.org/1999/xhtml" lang="en" xml:lang="en">
	<p>Strictly inspired by <a href="http://www.wikidata.org/entity/Q325283"><code>wikidata:Q325283</code></a>, but also drawing on more traditional folktales and ideas surrounding fairies, this was a story about a half‐fairy investigator working on a case spanning the human and fairy worlds.</p>
</div></contents>
		</dc:abstract>
