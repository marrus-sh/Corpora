		<identifier rdf:datatype="http://www.w3.org/2001/XMLSchema#NCName">bjmns</identifier>
		<fullTitle xml:lang="en">BJMNS Presents:</fullTitle>
		<hasCover rdf:parseType="Resource">
			<contents rdf:parseType="Literal"><svg xmlns="http://www.w3.org/2000/svg" version="1.1" viewBox="0 0 512 512" fill="currentColor" stroke="none">
	<title lang="en" xml:lang="en">A monogram of the letters ‹ BRS ›, which I used in conjunction with the BJMNS moniker, again replacing a TF monogram.</title>
	<g transform="translate(0,-540.36218)">
		<g transform="matrix(1.28,0,0,1.28,-64,-230.66142)">
			<g transform="translate(-20,10)">
				<path d="m 260,642.36218 c 60,0 80,10 80,50 0,40 -20,50 -60,50 l -10,0 c 0,0 50,0 50,-50 0,-50 -70,-50 -70,-50 z"/>
				<path d="m 280,742.36218 c 40,0 60,10 60,50 0,40 -20,50 -80,50 l -10,0 c 0,0 70,0 70,-50 0,-50 -50,-50 -50,-50 z"/>
				<path d="m 220,742.36218 c -40,0 -60,10 -60,50 0,40 40,50 90,50 l 0,0 c 0,0 -70,0 -70,-50 0,-50 50,-50 50,-50 z"/>
				<path d="m 260,942.36218 c 60,0 80,-10 80,-50 0,-40 -40,-50 -90,-50 l 0,0 c 0,0 70,0 70,50 0,50 -70,50 -70,50 z"/>
				<path d="m 280,742.36218 c 40,0 60,10 60,50 0,40 50,50 50,50 l -10,0 c 0,0 -60,0 -60,-50 0,-50 -50,-50 -50,-50 z"/>
				<path d="m 250,120 c 0,0 10,0 10,70 l 0,10 c 0,70 -10,70 -10,70 0,0 -10,-10 -10,-70 l 0,-10 c 0,-70 10,-70 10,-70 z" transform="translate(0,552.36218)"/>
			</g>
			<path d="M 250,50 C 139.54305,50 50,139.54305 50,250 50,360.45695 139.54305,450 250,450 360.45695,450 450,360.45695 450,250 450,139.54305 360.45695,50 250,50 z m 0,10 c 99.41125,0 180,85.0659 180,190 0,104.9341 -80.58875,190 -180,190 C 150.58875,440 70,354.9341 70,250 70,145.0659 150.58875,60 250,60 z" transform="translate(0,552.36218)"/>
		</g>
