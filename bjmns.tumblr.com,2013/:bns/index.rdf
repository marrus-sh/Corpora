	<Volume rdf:about="tag:bjmns.tumblr.com,2013:bns::3:4">
		<owl:sameAs rdf:resource="./3/4/"/>
		<owl:sameAs rdf:resource="#bjmns:3:4"/>
		<index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">4</index>
		<fullTitle xml:lang="en">The aftermath of WWIII</fullTitle>
		<dc:abstract rdf:parseType="Resource">
			<contents rdf:parseType="Literal"><div xmlns="http://www.w3.org/1999/xhtml" lang="en" xml:lang="en">
	<p>From the original project notes:</p>
	<blockquote>
		<p>Now Tyler’s existence is no longer secret, and not everybody wants him to exist.</p>
	</blockquote>
</div></contents>
		</dc:abstract>
		
	</Volume>
		</includes>
		<includes>
	<Volume rdf:about="tag:bjmns.tumblr.com,2013:bns::3:3">
		<owl:sameAs rdf:resource="./3/3/"/>
		<owl:sameAs rdf:resource="#bjmns:3:3"/>
		<index rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</index>
		<fullTitle xml:lang="en">We will be Invincible</fullTitle>
		<dc:abstract rdf:parseType="Resource">
			<contents rdf:parseType="Literal"><div xmlns="http://www.w3.org/1999/xhtml" lang="en" xml:lang="en">
	<p>From the original project notes:</p>
	<blockquote>
		<p>The 3rd World War is coming, and only Tyler can stop it.</p>
	</blockquote>
</div></contents>
		</dc:abstract>
		
	</Volume>
		</includes>
		<includes>
	<Volume rdf:about="tag:bjmns.tumblr.com,2013:bns::3:2">
