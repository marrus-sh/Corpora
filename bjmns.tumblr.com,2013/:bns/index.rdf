		<dc:abstract rdf:parseType="Resource">
			<contents rdf:parseType="Literal"><div xmlns="http://www.w3.org/1999/xhtml" lang="en" xml:lang="en">
	<p>From the original project notes:</p>
	<blockquote>
		<p>Story of how Tyler is killed, and why his mind still lives.</p>
	</blockquote>
</div></contents>
		</dc:abstract>
		
	</Volume>
