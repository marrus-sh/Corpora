		<fullTitle xml:lang="en">DROWNED: A Short Story in Plain Text</fullTitle>
		<abbreviatedTitle xml:lang="en">DROWNED</abbreviatedTitle>
		<isPublishedAs>
	<dcmitype:Text rdf:about="./2/1/1/2/text.md">
